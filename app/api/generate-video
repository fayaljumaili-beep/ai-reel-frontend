import { NextResponse } from "next/server";
import fs from "fs";
import path from "path";
import { exec } from "child_process";

export async function POST(req: Request) {
  try {
    const { audioUrl } = await req.json();

    const outputPath = "/tmp/output.mp4";

    // VERY simple ffmpeg example (Railway needed for this later)
    exec(
      `ffmpeg -loop 1 -i public/bg.mp4 -i ${audioUrl} -shortest -c:v libx264 -c:a aac ${outputPath}`,
      (err) => {
        if (err) {
          console.error(err);
        }
      }
    );

    return NextResponse.json({ videoUrl: "/output.mp4" });
  } catch (err) {
    return NextResponse.json({ error: "Video failed" }, { status: 500 });
  }
}